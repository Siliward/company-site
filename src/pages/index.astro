---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { company } from "../data/company";
import wordex from "../data/products/wordex.json";

const serviceExamples = [
  {
    title: "知识库和内部问答",
    text: "整合分散在文档、表格、系统和沟通记录中的信息，构建可检索、可追问、可持续维护的内部知识助手。"
  },
  {
    title: "流程自动化和效率工具",
    text: "围绕整理、归类、审核、生成、流转等高频重复工作，设计更稳定的自动化方案，降低人力消耗。"
  },
  {
    title: "正式文档和内容生产",
    text: "面向技术报告、论文、公文等正式文档场景，优化写作、排版、协作和交付效率。"
  }
];

const industries = ["企业办公", "科研教育", "软件研发", "运营管理", "知识服务", "智能制造"];

const process = [
  ["明确业务目标", "先对齐要解决的具体问题、适用范围和预期结果，避免项目一开始就失焦。"],
  ["评估数据与系统条件", "梳理现有资料、业务系统和流程约束，判断哪些可以直接接入，哪些需要补齐。"],
  ["小范围验证效果", "先在一个明确场景内完成验证，确认可行性、效果和投入产出，再决定后续范围。"],
  ["形成稳定交付", "在验证通过后，补齐权限、安全、稳定性和维护能力，交付可长期运行的工具或系统。"],
  ["持续优化迭代", "上线不是结束。我们会根据使用反馈继续优化，让系统真正进入日常工作。"]
];
---

<Layout title={`${company.name} - ${company.tagline}`} description={company.description} canonicalPath="/" theme="company">
  <!-- Hero -->
  <section class="mesh-bg aurora">
    <div class="section-shell grid min-h-[calc(100vh-64px)] items-center gap-14 py-20 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="rise">
        <p class="font-mono text-xs uppercase tracking-[0.32em] text-accent">{company.legalNameEn}</p>
        <h1 class="mt-7 font-display font-semibold text-content display-xl">
          让 AI 真正进入业务，<br />而不只是停留在 <span class="glow-text">演示里</span>。
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-8 text-muted">
          Siliward 面向企业提供 AI 产品与落地服务。<br class="hidden sm:block" />围绕知识管理、流程自动化和正式文档生产等场景，帮助团队把 AI 接入日常工作，形成可长期使用的工具和系统。
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="#products">看看我们的产品</ButtonLink>
          <ButtonLink href="#services" variant="secondary">我有个项目想聊</ButtonLink>
        </div>
        <p class="mt-8 text-sm text-faint">{company.legalNameZh}</p>
      </div>

      <!-- WordeX 文档预览 -->
      <div class="rise glow-ring rounded-theme-lg border border-line bg-surface p-5 backdrop-blur-sm sm:p-6" style="animation-delay:0.12s">
        <div class="flex items-center justify-between border-b border-line pb-4">
          <div class="flex items-center gap-2">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-accent-2"></span>
            <span class="h-3 w-3 rounded-full bg-accent"></span>
          </div>
          <span class="font-mono text-xs text-faint">WordeX · 一键成稿</span>
        </div>

        <div class="mt-5">
          <p class="text-xs font-semibold text-faint">你只管写内容</p>
          <div class="mt-2 rounded-theme bg-surface-strong p-4 font-mono text-sm leading-7 text-muted">
            <p><span class="text-accent">\include</span>{"{@builtin/tech.report.basic}"}</p>
            <p><span class="text-accent">\title</span>{"{技术报告模板使用说明}"}</p>
            <p><span class="text-accent">\section</span>{"{套用模板}"}</p>
          </div>
        </div>

        <div class="mt-4">
          <p class="text-xs font-semibold text-faint">模板负责排版，一键生成</p>
          <div class="mt-2 rounded-theme border border-line-strong bg-accent-soft p-4">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent text-xs font-bold text-accent-contrast">✓</span>
              <div>
                <p class="font-semibold text-content">技术报告.docx</p>
                <p class="mt-1 text-sm text-accent">排版规范 · Word 里可继续编辑</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 产品 -->
  <section id="products" class="border-t border-line bg-elev py-24">
    <div class="section-shell">
      <div class="reveal">
        <SectionHeading
          eyebrow="我们的产品"
          title="先把真实问题，做成顺手的工具"
          text="我们的产品从具体场景里长出来。先把一个真实、反复出现的问题解决好，再把它沉淀成可复用的产品能力。"
        />
      </div>
      <div class="mt-14">
        <article class="reveal flex flex-col rounded-theme-lg border border-line bg-surface p-8 transition hover:border-accent lg:p-10">
          <div class="flex items-center gap-3">
            <span class="rounded-full bg-surface-strong px-3 py-1 text-xs font-semibold text-muted">{wordex.status}</span>
            <span class="text-xs text-faint">在线文档工具</span>
          </div>
          <h3 class="mt-6 font-display text-4xl font-semibold text-content">{wordex.name}</h3>
          <p class="mt-2 text-lg font-semibold text-accent">{wordex.tagline}</p>
          <p class="mt-4 max-w-2xl text-base leading-8 text-muted">
            技术报告、期刊论文、公文这类正式文档，真正耗时的往往不是内容本身，而是排版、编号、模板和反复修改。WordeX 让你和 AI 专注内容生产，把版式规范和成稿交付交给模板处理。
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <ButtonLink href="/products/wordex">认识 WordeX</ButtonLink>
            <ButtonLink href="/wordex" variant="secondary">查看在线入口</ButtonLink>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- 服务 -->
  <section id="services" class="section-shell py-24">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent">也帮你做</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-content md:text-5xl">
        从具体场景开始，<br />把 AI 做进业务流程。
      </h2>
      <p class="mt-5 text-base leading-8 text-muted">
        我们更关注能不能接进现有系统、现有数据和现有流程，而不是只做一个演示结果。项目通常从单一场景起步，验证后再逐步扩展。
      </p>
    </div>
    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {serviceExamples.map((item, index) => (
        <article class="reveal group rounded-theme-lg border border-line bg-surface p-7 transition hover:border-accent" style={`--reveal-delay:${index * 0.08}s`}>
          <span class="font-mono text-sm text-accent">0{index + 1}</span>
          <h3 class="mt-4 font-display text-xl font-semibold text-content">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-muted">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- 怎么合作 -->
  <section class="border-y border-line bg-elev py-24">
    <div class="section-shell grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div class="reveal">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-accent">我们怎么合作</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content md:text-4xl">先验证，再扩展</h2>
        <p class="mt-4 text-sm leading-7 text-muted">
          我们通常不会一开始就铺开全部范围，而是先完成一个可验证、可衡量的小场景，再逐步形成稳定交付。
        </p>
      </div>
      <div class="grid gap-4">
        {process.map(([title, text], index) => (
          <div class="reveal flex gap-5 rounded-theme border border-line bg-surface p-5" style={`--reveal-delay:${index * 0.06}s`}>
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-theme bg-accent font-mono text-sm font-semibold text-accent-contrast">{index + 1}</span>
            <div>
              <h3 class="font-display text-lg font-semibold text-content">{title}</h3>
              <p class="mt-1 text-sm leading-6 text-muted">{text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 行业 -->
  <section class="section-shell py-20">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div class="reveal">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-accent">服务方向</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content md:text-4xl">不同行业，落地方式都离不开具体场景</h2>
        <p class="mt-4 text-sm leading-7 text-muted">无论来自哪个行业，真正能落地的项目，通常都从资料、流程、协作和交付中的具体问题开始。</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {industries.map((item, index) => (
          <div class="reveal rounded-theme border border-line bg-surface p-4 text-center text-sm font-semibold text-muted" style={`--reveal-delay:${index * 0.05}s`}>{item}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- 联系 -->
  <section class="section-shell py-24">
    <div class="reveal mesh-bg aurora overflow-hidden rounded-theme-lg border border-line-strong bg-surface p-10 text-center md:p-16">
      <p class="font-mono text-xs uppercase tracking-[0.16em] text-accent">说句话，我们就开始</p>
      <h2 class="mt-4 font-display font-semibold text-content display-xl">如果你正在评估某个场景，<span class="glow-text">欢迎和我们聊聊</span>。</h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-muted">
        如果你想讨论企业合作、业务场景或产品落地方案，欢迎发邮件到 contact@siliward.cn。<br class="hidden sm:block" />如果你想反馈产品问题或使用建议，也可以发到 feedback@siliward.cn。
      </p>
      <div class="mt-10 flex justify-center">
        <ButtonLink href={`mailto:${company.businessEmail}`}>咨询合作方案</ButtonLink>
      </div>
    </div>
  </section>
</Layout>
