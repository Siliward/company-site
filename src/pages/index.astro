---
import Layout from "../components/Layout.astro";
import { company } from "../data/company";
import wordex from "../data/products/wordex.json";
import { withBase } from "../utils/paths";

const tickerItems = [
  "AI 技术研发",
  "行业落地应用",
  "私有化部署",
  "定制化开发",
  "北京硅途数智科技有限公司",
  "Beijing Siliward Technology Co., Ltd.",
  "数智赋能千行百业",
  "WordeX 在线编辑器",
];
---

<Layout title={`${company.name} - ${company.tagline}`} description={company.description} canonicalPath="/" theme="company">

<style>
/* ═══════════════════════════════════════════════════════
   印刷局主题令牌
═══════════════════════════════════════════════════════ */
:root, [data-theme="company"] {
  color-scheme: light;
  --bg: #F4EFE5;
  --bg-dark: #1A1714;
  --ink: #1A1714;
  --ink-muted: rgba(26,23,20,0.55);
  --ink-faint: rgba(26,23,20,0.3);
  --red: #D4280A;
  --red-dark: #A81E08;
  --red-soft: rgba(212,40,10,0.08);
  --paper: #FAF7F0;
  --paper-warm: #EDE8DC;
  --line: rgba(26,23,20,0.12);
  --line-strong: rgba(26,23,20,0.25);
  --font-display: "Bebas Neue", "Noto Serif SC", serif;
  --font-serif: "Noto Serif SC", Georgia, serif;
  --font-mono: "IBM Plex Mono", monospace;
  --radius: 2px;
  --radius-lg: 4px;
  --nav-bg: rgba(244,239,229,0.92);
  --accent: #D4280A;
  --accent-contrast: #FAF7F0;
  --content: #1A1714;
  --content-muted: rgba(26,23,20,0.55);
  --content-faint: rgba(26,23,20,0.3);
  --surface: #FAF7F0;
  --bg-elev: #EDE8DC;
}

/* ═══════════════════════════════════════════════════════
   基础重置
═══════════════════════════════════════════════════════ */
body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-serif);
  cursor: default;
}

/* 纸张噪点纹理 */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 999;
  pointer-events: none;
  opacity: 0.035;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px;
}

/* ═══════════════════════════════════════════════════════
   导航栏覆盖
═══════════════════════════════════════════════════════ */
header {
  border-bottom-color: var(--line-strong) !important;
  background: var(--nav-bg) !important;
}

/* ═══════════════════════════════════════════════════════
   跑马灯滚动横幅
═══════════════════════════════════════════════════════ */
.ticker-wrap {
  background: var(--red);
  overflow: hidden;
  padding: 0.55rem 0;
  border-bottom: 1px solid var(--red-dark);
}
.ticker-track {
  display: flex;
  gap: 2.5rem;
  width: max-content;
  will-change: transform;
  animation: ticker-scroll 32s linear infinite;
}
.ticker-track:hover { animation-play-state: paused; }
.ticker-sequence {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  flex: 0 0 auto;
  white-space: nowrap;
  font-family: var(--font-display);
  font-size: 0.9rem;
  letter-spacing: 0.15em;
  color: var(--accent-contrast);
}
.ticker-sep {
  display: inline-block;
  width: 4px; height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  margin: 0 -1rem;
}
@keyframes ticker-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-25%); }
}

/* ═══════════════════════════════════════════════════════
   HERO — 报纸版面
═══════════════════════════════════════════════════════ */
.hero {
  border-bottom: 3px double var(--line-strong);
  padding: 0;
  position: relative;
  overflow: hidden;
}

/* 版面头部：期刊信息栏 */
.masthead {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 1.1rem 0;
  border-bottom: 1px solid var(--line-strong);
  gap: 1.5rem;
}
.masthead-rule {
  height: 1px;
  background: var(--line-strong);
}
.masthead-center {
  text-align: center;
}
.masthead-title {
  font-family: var(--font-display);
  font-size: 1.6rem;
  letter-spacing: 0.35em;
  color: var(--ink);
  line-height: 1;
}
.masthead-sub {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  color: var(--ink-muted);
  margin-top: 0.25rem;
}
.masthead-meta {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  color: var(--ink-faint);
  line-height: 1.6;
}
.masthead-meta-r { text-align: right; }

/* 主体大字区 */
.hero-body {
  padding: 3rem 0 0;
  position: relative;
}

/* 竖线装饰 */
.vert-rule {
  position: absolute;
  top: 0; bottom: 0;
  width: 1px;
  background: var(--line-strong);
}

.hero-layout {
  display: grid;
  grid-template-columns: 2.5rem 1fr 1.5rem 340px;
  gap: 0;
  align-items: start;
  position: relative;
}

/* 竖排期刊号 */
.hero-vol {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  color: var(--ink-faint);
  text-transform: uppercase;
  padding-top: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  border-right: 1px solid var(--line);
  padding-right: 0.75rem;
  height: 100%;
}

/* 中央大字 */
.hero-main { padding: 0 2.5rem; }

.hero-kicker {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 1.2rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  opacity: 0;
  animation: press-up 0.7s 0.1s cubic-bezier(0.22,1,0.36,1) forwards;
}
.kicker-rule {
  flex: 1;
  height: 1px;
  background: var(--red);
  opacity: 0.35;
}

.hero-headline {
  font-family: var(--font-display);
  font-size: clamp(5rem, 13vw, 10rem);
  line-height: 0.92;
  letter-spacing: 0.01em;
  color: var(--ink);
  margin: 0;
  opacity: 0;
  animation: press-up 0.9s 0.22s cubic-bezier(0.22,1,0.36,1) forwards;
}
.headline-red { color: var(--red); }
.headline-outline {
  -webkit-text-stroke: 2px var(--ink);
  color: transparent;
}

/* 分割双线 */
.editorial-double {
  border-top: 1px solid var(--line-strong);
  border-bottom: 3px solid var(--ink);
  height: 4px;
  margin: 1.8rem 0;
  opacity: 0;
  animation: press-up 0.6s 0.5s cubic-bezier(0.22,1,0.36,1) forwards;
}

.hero-deck {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  line-height: 1.85;
  color: var(--ink-muted);
  max-width: 44ch;
  column-count: 2;
  column-gap: 2rem;
  column-rule: 1px solid var(--line);
  opacity: 0;
  animation: press-up 0.8s 0.6s cubic-bezier(0.22,1,0.36,1) forwards;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  margin-top: 2rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: press-up 0.7s 0.75s cubic-bezier(0.22,1,0.36,1) forwards;
}

/* 右栏：特写框 */
.hero-sidebar {
  border-left: 1px solid var(--line-strong);
  padding: 0 0 2rem 1.5rem;
  position: relative;
}

.sidebar-label {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--red);
  background: var(--red);
  color: var(--accent-contrast);
  padding: 0.2rem 0.6rem;
  display: inline-block;
  margin-bottom: 1.25rem;
}

/* 产品镜框 */
.sidebar-frame {
  background: var(--bg-dark);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 4px;
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
  opacity: 0;
  animation: press-up 1s 0.38s cubic-bezier(0.22,1,0.36,1) forwards;
}
.sidebar-frame::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 30% 0%, rgba(212,40,10,0.12) 0%, transparent 70%);
  pointer-events: none;
}

.frame-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.65rem;
  border: 1px solid rgba(212,40,10,0.4);
  border-radius: 2px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  color: var(--red);
}
.frame-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--red);
  animation: pulse-red 2s ease-in-out infinite;
}
@keyframes pulse-red {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.3; }
}

.frame-name {
  font-family: var(--font-display);
  font-size: 3.5rem;
  line-height: 0.95;
  letter-spacing: 0.04em;
  color: #FAF7F0;
  margin: 1rem 0 0.25rem;
  -webkit-text-stroke: 0;
}
.frame-tagline {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--red);
}
.frame-desc {
  font-family: var(--font-serif);
  font-size: 0.8rem;
  line-height: 1.75;
  color: rgba(244,239,229,0.55);
  margin-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 1rem;
}
.frame-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 1rem;
}
.frame-tag {
  padding: 0.2rem 0.55rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 2px;
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  color: rgba(244,239,229,0.45);
  transition: all 0.2s;
}
.frame-tag:hover {
  background: rgba(212,40,10,0.12);
  border-color: rgba(212,40,10,0.35);
  color: var(--red);
}
.frame-cta {
  margin-top: 1.25rem;
  display: flex;
  gap: 0.6rem;
}

/* ═══════════════════════════════════════════════════════
   按钮
═══════════════════════════════════════════════════════ */
.btn-ink {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.6rem;
  background: var(--ink);
  color: var(--paper);
  font-family: var(--font-display);
  font-size: 0.95rem;
  letter-spacing: 0.12em;
  border-radius: var(--radius);
  transition: transform 0.18s, background 0.18s;
  position: relative;
  overflow: hidden;
}
.btn-ink::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform 0.5s;
}
.btn-ink:hover::after { transform: translateX(100%); }
.btn-ink:hover {
  background: var(--red);
  transform: translateY(-2px);
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.6rem;
  background: transparent;
  color: var(--ink);
  font-family: var(--font-display);
  font-size: 0.95rem;
  letter-spacing: 0.12em;
  border-radius: var(--radius);
  border: 1.5px solid var(--ink);
  transition: all 0.2s;
}
.btn-outline:hover {
  background: var(--ink);
  color: var(--paper);
  transform: translateY(-2px);
}

.btn-frame {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.55rem 1.1rem;
  background: var(--red);
  color: var(--accent-contrast);
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  border-radius: var(--radius);
  transition: all 0.2s;
}
.btn-frame:hover {
  background: #FAF7F0;
  color: var(--red);
  transform: translateY(-1px);
}
.btn-frame-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.55rem 1.1rem;
  background: transparent;
  color: rgba(244,239,229,0.6);
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  border-radius: var(--radius);
  border: 1px solid rgba(255,255,255,0.12);
  transition: all 0.2s;
}
.btn-frame-ghost:hover {
  color: #FAF7F0;
  border-color: rgba(255,255,255,0.3);
}

/* ═══════════════════════════════════════════════════════
   数字计数条
═══════════════════════════════════════════════════════ */
.stat-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line);
  margin: 2.5rem 0 0;
}
.stat-item {
  padding: 1.25rem 0;
  border-right: 1px solid var(--line);
  text-align: center;
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: var(--font-display);
  font-size: 2rem;
  letter-spacing: 0.05em;
  color: var(--ink);
  line-height: 1;
}
.stat-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  margin-top: 0.3rem;
}

/* ═══════════════════════════════════════════════════════
   服务区 — 不对称网格
═══════════════════════════════════════════════════════ */
.services-section {
  border-top: 3px double var(--line-strong);
  padding: 5rem 0;
}

.services-header {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 3rem;
  align-items: end;
  margin-bottom: 3.5rem;
}

.section-num {
  font-family: var(--font-display);
  font-size: 5rem;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--red);
  -webkit-text-stroke: 1.5px var(--red);
  color: transparent;
}

.section-heading {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  letter-spacing: 0.04em;
  line-height: 1;
  color: var(--ink);
}
.section-heading-sub {
  font-family: var(--font-serif);
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--ink-muted);
  margin-top: 0.75rem;
}

.services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  border: 1.5px solid var(--line-strong);
}

.service-item {
  padding: 2.25rem;
  border-right: 1px solid var(--line-strong);
  position: relative;
  overflow: hidden;
  transition: background 0.3s;
  cursor: default;
}
.service-item:last-child { border-right: none; }
.service-item:hover { background: var(--paper-warm); }

.service-item::before {
  content: "";
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--red);
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
}
.service-item:hover::before { transform: scaleY(1); }

.svc-num {
  font-family: var(--font-display);
  font-size: 3rem;
  line-height: 1;
  letter-spacing: 0.02em;
  color: var(--line-strong);
  display: block;
  margin-bottom: 1.25rem;
}
.svc-title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  letter-spacing: 0.08em;
  color: var(--ink);
  margin-bottom: 0.75rem;
}
.svc-text {
  font-family: var(--font-serif);
  font-size: 0.875rem;
  line-height: 1.85;
  color: var(--ink-muted);
}

/* ═══════════════════════════════════════════════════════
   CTA — 全幅黑底
═══════════════════════════════════════════════════════ */
.cta-section {
  background: var(--bg-dark);
  padding: 6rem 0;
  position: relative;
  overflow: hidden;
}
.cta-section::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--red);
}
.cta-section::after {
  content: "SILIWARD";
  position: absolute;
  bottom: -1rem; right: -0.5rem;
  font-family: var(--font-display);
  font-size: clamp(6rem, 18vw, 16rem);
  letter-spacing: -0.04em;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,0.04);
  pointer-events: none;
  user-select: none;
  line-height: 1;
}

.cta-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 4rem;
}

.cta-headline {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 6rem);
  line-height: 0.95;
  letter-spacing: 0.02em;
  color: var(--paper);
  position: relative;
}
.cta-red { color: var(--red); }

.cta-sub {
  font-family: var(--font-serif);
  font-size: 1rem;
  line-height: 1.85;
  color: rgba(244,239,229,0.5);
  margin-top: 1.25rem;
  max-width: 38ch;
}

.cta-actions {
  display: flex;
  gap: 1rem;
  flex-direction: column;
  align-items: flex-start;
  flex-shrink: 0;
}

.btn-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 1rem 2.2rem;
  background: var(--red);
  color: var(--accent-contrast);
  font-family: var(--font-display);
  font-size: 1.1rem;
  letter-spacing: 0.12em;
  border-radius: var(--radius);
  white-space: nowrap;
  transition: all 0.22s;
  box-shadow: 4px 4px 0 rgba(212,40,10,0.3);
}
.btn-cta-primary:hover {
  transform: translate(-2px,-2px);
  box-shadow: 6px 6px 0 rgba(212,40,10,0.4);
}

.btn-cta-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.85rem 1.8rem;
  background: transparent;
  color: rgba(244,239,229,0.55);
  font-family: var(--font-display);
  font-size: 0.95rem;
  letter-spacing: 0.12em;
  border-radius: var(--radius);
  border: 1px solid rgba(244,239,229,0.15);
  white-space: nowrap;
  transition: all 0.22s;
}
.btn-cta-ghost:hover {
  color: var(--paper);
  border-color: rgba(244,239,229,0.4);
}

/* ═══════════════════════════════════════════════════════
   公用
═══════════════════════════════════════════════════════ */
@keyframes press-up {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1);
  transition-delay: var(--reveal-delay, 0s);
}
.reveal.is-visible { opacity: 1; transform: none; }

.section-shell {
  width: min(1160px, calc(100% - 40px));
  margin-inline: auto;
}

/* ═══════════════════════════════════════════════════════
   响应式
═══════════════════════════════════════════════════════ */
@media (max-width: 900px) {
  .hero-layout { grid-template-columns: 0 1fr 0 1fr; }
  .hero-vol { display: none; }
  .hero-sidebar { border-left: none; border-top: 1px solid var(--line-strong); padding: 1.5rem 0 0; }
  .hero-deck { column-count: 1; }
  .cta-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .services-grid { grid-template-columns: 1fr; }
  .service-item { border-right: none; border-bottom: 1px solid var(--line-strong); }
  .service-item:last-child { border-bottom: none; }
  .masthead { grid-template-columns: 1fr; justify-items: center; gap: 0.5rem; }
  .masthead-rule { display: none; }
  .masthead-meta-r { text-align: center; }
  .masthead-meta:first-child { display: none; }
}

@media (max-width: 600px) {
  .hero-layout { grid-template-columns: 1fr; }
  .stat-strip { grid-template-columns: repeat(3, 1fr); }
  .hero-headline { font-size: clamp(3.5rem, 16vw, 5rem); }
}

@media (prefers-reduced-motion: reduce) {
  .press-up, .reveal { animation: none; opacity: 1; transform: none; }
}
</style>

