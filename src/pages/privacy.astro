---
import Layout from "../components/Layout.astro";
import { company } from "../data/company";

const sections = [
  ["我们会处理哪些信息", "访问官网时，我们可能记录访问日志和页面点击；如果你主动联系我们，会收到你提交的联系方式。使用 WordeX 在线服务时，你的文档项目和素材保存在你的账户空间内。"],
  ["AI 功能与你的数据", "使用你自己的模型账号时，你输入的内容会发送到你选择的服务商。未来如果我们提供代为转发的 AI 服务，上线前会单独、清楚地说明数据如何处理、保留多久、如何计费以及如何申请删除。"],
  ["你的权利", "你可以要求查看、更正或删除与官网账号或在线服务相关的数据。"],
  ["联系我们", null]
];
---

<Layout title="隐私政策" description="Siliward 与 WordeX 的隐私政策。" canonicalPath="/privacy" theme="company">
  <section class="section-shell max-w-4xl py-20">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">隐私政策</p>
    <h1 class="mt-4 font-display text-4xl font-semibold text-content md:text-5xl">我们如何对待你的数据</h1>
    <p class="mt-5 text-sm leading-7 text-faint">最后更新：2026-05-10。本页为产品上线前的草案，正式发布前会由法务按目标地区确认。</p>

    <div class="mt-12 space-y-10">
      {sections.map(([title, body]) => (
        <section class="reveal">
          <h2 class="font-display text-2xl font-semibold text-content">{title}</h2>
          {body ? (
            <p class="mt-3 text-base leading-8 text-muted">{body}</p>
          ) : (
            <p class="mt-3 text-base leading-8 text-muted">
              商务合作请联系
              <a class="text-accent underline underline-offset-4" href={`mailto:${company.businessEmail}`}>{company.businessEmail}</a>；
              用户反馈请联系
              <a class="text-accent underline underline-offset-4" href={`mailto:${company.feedbackEmail}`}>{company.feedbackEmail}</a>。
            </p>
          )}
        </section>
      ))}
    </div>
  </section>
</Layout>
