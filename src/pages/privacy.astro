---
import Layout from "../components/Layout.astro";
import { company } from "../data/company";

const sections = [
  [
    "适用范围",
    `${company.name} 官网、WordeX 产品介绍页、在线编辑器及后续相关在线服务，均适用本页所述的隐私处理原则。不同服务如有额外的数据处理规则，我们会在相应页面另行说明。`
  ],
  [
    "我们会收集哪些信息",
    "当你浏览官网时，我们可能收集基础访问日志、设备信息、页面访问记录和错误日志，用于网站运行、安全审计与体验优化。当你通过邮件或表单联系我们时，我们会收到你主动提交的姓名、公司、邮箱、电话或需求描述等信息。当你使用 WordeX 在线服务时，我们还可能处理你的账号信息、文档项目、上传素材、操作记录和导出记录。"
  ],
  [
    "我们为什么处理这些信息",
    "我们处理相关信息，主要用于提供和维护服务、识别故障与安全风险、回应咨询与支持请求、改进产品体验、统计服务使用情况，以及履行法律法规要求。除非另有明确说明，我们不会为了与服务无关的目的使用你的内容数据。"
  ],
  [
    "AI 功能与你的数据",
    "当你使用自带模型账号或外部 API Key 时，你输入的内容会按你的配置发送到相应第三方模型服务商，相关数据处理规则适用其条款。若未来我们提供平台代转发的 AI 服务，我们会在正式上线前单独说明数据的处理方式、保存时长、调用计费、删除路径与安全措施。"
  ],
  [
    "数据保存与安全",
    "我们会在实现服务目的所必需的期限内保存相关数据，并采取合理的技术与管理措施降低未授权访问、泄露、篡改或丢失风险。不同类型的数据保存期限可能不同；在服务停止、账号注销或你依法提出删除请求后，我们会在合理期限内处理相关数据，但法律法规另有要求的除外。"
  ],
  [
    "信息共享与披露",
    "除以下情形外，我们不会向无关第三方出售或披露你的个人信息：为提供服务而必需的技术供应商协助、你明确授权的共享、法律法规或监管要求、以及为保护我们或他人合法权益所必需的情形。如涉及重要第三方处理，我们会尽量在产品或文档中保持说明透明。"
  ],
  [
    "你的权利",
    "在适用法律允许的范围内，你可以申请访问、更正、删除与你相关的数据，也可以申请注销账号、撤回授权或询问数据处理情况。为保障安全，我们可能在处理请求前验证你的身份。"
  ],
  [
    "未成年人说明",
    "我们的服务主要面向具备完全民事行为能力的个人和机构用户。若你是未成年人，请在监护人指导下使用相关服务；如我们发现未经适当授权收集了未成年人信息，会在核实后尽快处理。"
  ],
  [
    "政策更新",
    "随着产品能力、法律要求或服务方式变化，我们可能更新本隐私政策。若更新会对你的权利产生重大影响，我们会通过官网、产品页面或其他合理方式提示。"
  ],
  ["联系我们", null]
];
---

<Layout title="隐私政策" description="Siliward 与 WordeX 的隐私政策。" canonicalPath="/privacy" theme="company">
  <section class="section-shell max-w-4xl py-20">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">隐私政策</p>
    <h1 class="mt-4 font-display text-4xl font-semibold text-content md:text-5xl">我们如何对待你的数据</h1>
    <p class="mt-5 text-sm leading-7 text-faint">最后更新：2026-06-23。本页为上线前版本，正式发布前仍应结合目标地区、产品形态和实际数据流转情况进行法务复核。</p>

    <div class="mt-12 space-y-10">
      {sections.map(([title, body]) => (
        <section class="reveal">
          <h2 class="font-display text-2xl font-semibold text-content">{title}</h2>
          {body ? (
            <p class="mt-3 text-base leading-8 text-muted">{body}</p>
          ) : (
            <p class="mt-3 text-base leading-8 text-muted">
              商务合作请联系
              <a class="text-accent underline underline-offset-4" href={`mailto:${company.businessEmail}`}>{company.businessEmail}</a>；
              用户反馈请联系
              <a class="text-accent underline underline-offset-4" href={`mailto:${company.feedbackEmail}`}>{company.feedbackEmail}</a>。
            </p>
          )}
        </section>
      ))}
    </div>
  </section>
</Layout>
