---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { company } from "../data/company";
import wordex from "../data/products/wordex.json";
---

<Layout title="WordeX 在线编辑器" description="WordeX 在线编辑器正在内部测试。" canonicalPath="/wordex" theme="wordex">
  <section class="section-shell grid min-h-[calc(100vh-64px)] items-center gap-10 py-16 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="rise">
      <p class="editorial-kicker text-xs text-accent">在线编辑器</p>
      <h1 class="mt-5 max-w-3xl font-display text-5xl font-semibold leading-[1.12] tracking-tight text-content md:text-6xl">
        WordeX 正在内部测试
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-muted">
        在线编辑器当前仅面向内部测试。建文档、写内容、一键生成规范的 Word，都会在这个入口完成。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <ButtonLink href="/products/wordex">了解产品</ButtonLink>
        <ButtonLink href={`mailto:${company.contactEmail}`} variant="secondary">联系我们</ButtonLink>
      </div>
    </div>

    <div class="rise border border-line bg-surface p-8 shadow-soft" style="animation-delay:0.1s">
      <div class="border-b border-line pb-5">
        <p class="editorial-kicker text-xs text-accent">{wordex.status}</p>
        <p class="mt-3 font-display text-3xl font-semibold text-content">测试中</p>
      </div>
      <div class="mt-6 grid gap-4">
        {[
          ["文档项目", "在线管理你的稿件与素材"],
          ["在线编辑", "专注写内容，模板负责排版"],
          ["一键成稿", "随时生成可编辑的 Word 文档"]
        ].map(([title, sub]) => (
          <div class="flex items-center justify-between border-l-2 border-line-strong pl-4">
            <div>
              <p class="font-display text-base font-semibold text-content">{title}</p>
              <p class="mt-1 text-sm text-muted">{sub}</p>
            </div>
            <span class="editorial-kicker text-xs text-faint">测试中</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
