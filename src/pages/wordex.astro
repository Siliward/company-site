---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { company } from "../data/company";
import wordex from "../data/products/wordex.json";
---

<Layout title="WordeX Online Editor" description="WordeX online editor reserved entry." canonicalPath="/wordex">
  <section class="section-shell grid min-h-[calc(100vh-64px)] items-center gap-10 py-16 lg:grid-cols-[0.92fr_1.08fr]">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Reserved for WordeX</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-semibold tracking-normal text-ink md:text-6xl">
        WordeX 在线编辑器即将开放
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/68">
        这里是 WordeX 在线编辑器的预留入口。正式部署后，用户将在这个路径创建项目、编辑 .wex 文档并编译 Word .docx。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <ButtonLink href="/products/wordex">查看产品介绍</ButtonLink>
        <ButtonLink href={`mailto:${company.contactEmail}`} variant="secondary">联系 Siliward</ButtonLink>
      </div>
    </div>

    <div class="rounded-lg border border-ink/10 bg-white p-6 shadow-soft">
      <div class="rounded-lg bg-ink p-6 text-white">
        <p class="text-sm font-semibold uppercase tracking-wider text-moss">{wordex.status}</p>
        <h2 class="mt-3 text-3xl font-semibold">/wordex</h2>
        <p class="mt-4 text-sm leading-6 text-white/68">该路径会保留给未来在线编辑器应用，不指向私有 GitHub 仓库。</p>
      </div>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        {["Project workspace", "WEX editor", "DOCX compile"].map((item) => (
          <div class="rounded-lg border border-ink/10 bg-cloud p-4">
            <p class="text-sm font-semibold text-ink">{item}</p>
            <div class="mt-4 h-2 rounded-full bg-mint">
              <div class="h-2 w-2/3 rounded-full bg-moss"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
