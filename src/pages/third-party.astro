---
import Layout from "../components/Layout.astro";

const notices = [
  ["模型服务", "WordeX 支持 OpenAI、DeepSeek 或其他兼容接口的模型服务。使用你自己的模型账号时，数据处理遵循你所选服务商的条款。"],
  ["开源依赖", "我们的产品基于成熟的开源技术构建。正式发布前，我们会在网页上公开完整的开源许可证清单。"],
  ["素材授权", "官网的图标、截图和宣传视觉，在正式发布前都会取得可商用授权。参考用的网络素材和第三方标识不会被沿用。"],
  ["安全反馈", "如果你发现安全漏洞或供应链问题，欢迎通过官网公布的安全邮箱联系我们；专用邮箱上线前先使用联系邮箱。"]
];
---

<Layout title="第三方与开源说明" description="WordeX 的模型服务、开源依赖与素材授权说明。" canonicalPath="/third-party" theme="company">
  <section class="section-shell max-w-4xl py-20">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">第三方与开源</p>
    <h1 class="mt-4 font-display text-4xl font-semibold text-content md:text-5xl">我们用到的服务与素材</h1>
    <p class="mt-5 text-base leading-7 text-muted">这里集中说明模型服务、开源依赖和素材授权情况。正式发布前会补齐完整的许可证清单和授权文件。</p>

    <div class="mt-12 grid gap-5">
      {notices.map(([title, text], index) => (
        <article class="reveal rounded-theme-lg border border-line bg-surface p-7" style={`--reveal-delay:${index * 0.06}s`}>
          <h2 class="font-display text-2xl font-semibold text-content">{title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{text}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
