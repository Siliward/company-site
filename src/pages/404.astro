---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
---

<Layout title="页面不存在" description="未找到页面。" canonicalPath="/404" theme="company">
  <section class="mesh-bg aurora">
    <div class="section-shell flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-accent">404</p>
      <h1 class="mt-5 font-display font-semibold text-content display-xl"><span class="glow-text">这里空空如也</span></h1>
      <p class="mt-6 max-w-xl text-base leading-7 text-muted">你找的页面可能搬家了，或者还没和大家见面。不如先回首页看看？</p>
      <div class="mt-9">
        <ButtonLink href="/">回到首页</ButtonLink>
      </div>
    </div>
  </section>
</Layout>
