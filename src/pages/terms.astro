---
import Layout from "../components/Layout.astro";
import { company } from "../data/company";

const sections = [
  ["我们提供什么", `${company.name} 提供公司官网、WordeX 在线文档服务，以及未来可能上线的代转发 AI 服务。`],
  ["你需要遵守什么", "请确保你输入的内容、上传的文件，以及使用第三方模型账号的方式，都符合相关法律、所用服务的条款和你所在组织的规定。"],
  ["关于第三方模型", "使用你自己的模型账号时，模型服务由你选择的第三方提供。它们的可用性、费用和数据处理规则，适用各自的条款。"],
  ["关于托管 AI 服务", "代转发的 AI 服务尚未开放。上线前我们会补充订阅、额度、退款、滥用处理和数据保留等条款。"],
  ["免责说明", "AI 生成的内容可能不准确。涉及法律、医疗、财务和正式材料等重要事项时，请务必自行核实。"]
];
---

<Layout title="用户协议" description="Siliward 与 WordeX 的用户协议。" canonicalPath="/terms" theme="company">
  <section class="section-shell max-w-4xl py-20">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">用户协议</p>
    <h1 class="mt-4 font-display text-4xl font-semibold text-content md:text-5xl">使用我们的服务前，请了解</h1>
    <p class="mt-5 text-sm leading-7 text-faint">最后更新：2026-05-10。本页为首版占位，正式发布前会经法务审核。</p>

    <div class="mt-12 space-y-10">
      {sections.map(([title, body]) => (
        <section class="reveal">
          <h2 class="font-display text-2xl font-semibold text-content">{title}</h2>
          <p class="mt-3 text-base leading-8 text-muted">{body}</p>
        </section>
      ))}
    </div>
  </section>
</Layout>
