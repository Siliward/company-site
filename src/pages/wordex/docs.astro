---
import Layout from "../../components/Layout.astro";
import ButtonLink from "../../components/ButtonLink.astro";

const navItems = [
  ["概览", "#overview"],
  ["生成流程", "#lifecycle-overview"],
  ["文档项目", "#project-workspace"],
  ["写法基础", "#wex-basics"],
  ["命令参考", "#core-commands"],
  ["模板", "#template-packages"],
  ["从 Word 提取模板", "#docx-template-extraction"],
  ["测试状态", "#availability"]
];

const lifecycleSteps = [
  ["写源文件", "作者或大模型编写源文件，描述文档标题、元数据、章节、图表、公式和引用。"],
  ["载入模板", "WordeX 载入引入的模板，执行配置、样式、字段别名等设置。"],
  ["整理结构", "把内容整理成统一的中间结构，保留章节、段落、题注、编号和引用关系。"],
  ["生成 Word", "将整理好的结构和最终样式渲染为 Microsoft Word 可打开的 .docx 文件。"]
];

const quickstartCode = `\\include{@builtin/tech.report.basic}

\\title{技术报告模板使用说明}
\\issuer{硅途数智}
\\date{2026-06-10}

\\section{套用模板}

在文首引入内置模板，填好标题、单位与日期，正文按章节书写即可，版式由模板统一接管。

\\figure{assets/structure.png}[caption=模板章节结构示意,label=fig:structure,width=420]

模板结构见\\ref{fig:structure}。`;

const tableCode = `\\table{测试设备清单}[label=tab:equipment,style=grid]{
| 设备名称 | 型号 | 编号 |
| 接收机 | ESR 7 | A001 |
}`;

const templateCode = `\\include{@builtin/tech.report.basic}

\\style{section.1}{
  size: 18
  color: "#1F4E79"
}

\\alias{journalyear}{meta:journalYear}
\\journalyear{2026}`;

const extractionCode = `npm run wordex -- extract-template ./reference.docx -o ./templates/my.template --name my.template
npm run wordex -- verify-template ./templates/my.template
npm run wordex -- build ./main.wex -o ./dist/my-template-check.docx`;

const commandGroups = [
  {
    title: "模板与配置",
    text: "控制模板引入、页面配置、编号、渲染和样式，主要由模板使用。",
    commands: [
      ["\\include{path}", "载入模板或其他 WEX 文件。支持 @builtin、@project、@current、@user 和相对路径。"],
      ["\\config{name}{value}", "写入规则配置，例如 requiredMeta、allowedBlocks、maxSectionDepth。"],
      ["\\page{...}", "等价于 \\config{page}{...}，描述纸张、页边距、分栏、页眉页脚等页面规则。"],
      ["\\numbering{...}", "等价于 \\config{numbering}{...}，描述章节、图表、公式等编号规则。"],
      ["\\render{...}", "等价于 \\config{render}{...}，描述渲染阶段选项。"],
      ["\\style{role}{patch}", "修改最终样式 role，支持 key=value 和结构化块。"],
      ["\\alias{name}{meta:key}", "为模板字段注册友好的元数据命令，例如 \\journalyear{2026}。"]
    ]
  },
  {
    title: "常用元数据",
    text: "描述标题、日期、签发单位和通用元数据。",
    commands: [
      ["\\title{...}", "文档标题。"],
      ["\\issuer{...}", "签发单位、出具单位或署名单位。"],
      ["\\date{YYYY-MM-DD}", "文档日期。"],
      ["\\recipients{...}", "主送对象；支持顿号、中文逗号或英文逗号分隔。"],
      ["\\meta{key}{value}", "写入任意结构化元数据路径，例如 journal.name.zh。"]
    ]
  },
  {
    title: "期刊元数据",
    text: "期刊、论文和报告模板常用的内置元数据命令。",
    commands: [
      ["\\doi{...}", "DOI。"],
      ["\\editornote{...}", "编辑说明。"],
      ["\\author{...}", "作者；可重复使用形成作者列表。"],
      ["\\affiliation{...}", "作者单位；可重复使用。"],
      ["\\classification{...}", "分类号。"],
      ["\\abstract{...}", "中文摘要。"],
      ["\\keywords{...}", "中文关键词；按分号、逗号、顿号分隔。"],
      ["\\correspondence{...}", "通信作者或联系信息；可重复使用。"],
      ["\\englishtitle{...}", "英文标题。"],
      ["\\englishauthor{...}", "英文作者；可重复使用。"],
      ["\\englishaffiliation{...}", "英文单位；可重复使用。"],
      ["\\englishabstract{...}", "英文摘要。"],
      ["\\englishkeywords{...}", "英文关键词；按分隔符拆分。"],
      ["\\fund{...}", "基金项目。"],
      ["\\received{...}", "收稿日期。"],
      ["\\revised{...}", "修回日期。"],
      ["\\authorbio{...}", "作者简介；可重复使用。"]
    ]
  },
  {
    title: "结构与正文",
    text: "构建正文结构、段落、列表、附件、题注和标签。",
    commands: [
      ["\\section{...}", "一级标题，可带 [role=...] 覆盖样式 role。"],
      ["\\subsection{...}", "二级标题，可带 [role=...]。"],
      ["\\subsubsection{...}", "三级标题，可带 [role=...]。"],
      ["\\paragraph{...}", "显式段落；可带 [role=docx.someStyle]。"],
      ["\\item{...}", "列表项。"],
      ["\\attachment{...}[from=...]", "附件块，from 指向项目内文件。"],
      ["\\caption{...}", "显式题注块。"],
      ["\\label{id}", "把标签附加到前一个可编号结构，例如公式。"]
    ]
  },
  {
    title: "图片、表格与引用",
    text: "插入图片、表格、交叉引用和参考文献。",
    commands: [
      ["\\figure{path}[caption=...,label=...,width=...]", "图片；支持 captionEn、role、captionRole。"],
      ["\\table{caption}[label=...,style=grid]{...}", "表格；支持 pipe 表格和结构化单元格。"],
      ["\\row[header]{...}", "结构化表格内部命令，定义一行。"],
      ["\\th[colspan=...,rowspan=...]{...}", "结构化表格内部命令，定义表头单元格。"],
      ["\\td[colspan=...,rowspan=...]{...}", "结构化表格内部命令，定义普通单元格。"],
      ["\\bibitem{id}{text}", "声明参考文献条目。"],
      ["\\cite{id}", "正文内引用参考文献，渲染为编号交叉引用。"],
      ["\\ref{id}", "正文内引用图片、表格或公式标签。"]
    ]
  },
  {
    title: "公式语法",
    text: "公式不是普通命令注册项，但由解析器支持，并在生成阶段编号和渲染。",
    commands: [
      ["$...$", "行内公式。"],
      ["\\(...\\)", "行内公式。"],
      ["\\[...\\]", "不带 equation 环境的展示公式。"],
      ["\\begin{equation}...\\end{equation}", "编号展示公式，可紧跟 \\label{eq:id}。"],
      ["\\begin{equation*}...\\end{equation*}", "不带编号的展示公式。"]
    ]
  }
];

const commandReferenceText = commandGroups
  .map((group) => [
    `### ${group.title}`,
    group.text,
    "",
    ...group.commands.map(([syntax, description]) => `- \`${syntax}\`：${description}`)
  ].join("\n"))
  .join("\n\n");

const llmGuide = `# WordeX / WEX 使用说明

WordeX 是面向中文正式 Word 文档的语义化文档编译器。作者或大模型编写 .wex 源文件描述文档语义，模板包决定这些语义如何渲染为 Word .docx。

## 核心概念

- 不要把 WordeX 当作在线 Word。WordeX 的重点是用源文件和模板包稳定生成 .docx。
- .wex 文件描述标题、元数据、章节、段落、图片、表格、公式、引用和参考文献。
- 模板包描述页面、样式、编号、字段别名和渲染规则。
- 输出是标准 Word .docx，可在 Microsoft Word 中继续打开和编辑。

## 生成流程

WEX 源文件 -> 解析 -> 载入模板 -> 整理结构 -> 生成 DOCX

1. 写源文件：编写 .wex 文件。
2. 载入模板：载入引入的模板，执行配置、样式、字段别名等设置。
3. 整理结构：把内容整理成统一的中间结构，保留章节、段落、题注、编号和引用关系。
4. 生成 Word：将整理好的结构和最终样式渲染为 .docx 文件。

## 常用命令

${commandReferenceText}

## 路径前缀

- @builtin/：内置模板目录。
- @project/：当前项目根目录。
- @current/：当前文件所在目录。
- @user/：用户全局 WEX 目录。
- 无前缀路径等价于相对当前文件。

## 技术报告示例

\`\`\`latex
${quickstartCode}
\`\`\`

## 表格示例

\`\`\`latex
${tableCode}
\`\`\`

## 模板和样式示例

\`\`\`latex
${templateCode}
\`\`\`

常见样式 role 包括 title、paragraph、section.1、section.2、section.3、formula.display、figure.caption、table.default、table.caption、references.heading、reference.item。

## 从 Word 提取模板

WordeX 可以把参考 DOCX 提取成可编辑的 WEX 模板包初稿。参考 DOCX 只在提取阶段读取，正式生成仍走 WEX -> DOCX 的标准链路。

\`\`\`bash
${extractionCode}
\`\`\`

生成的模板包通常包含：

- index.wex
- page.wex
- styles.wex
- aliases.wex
- AGENTS.md
- package.json
- assets/

模板效果与原 DOCX 有差异时，优先修改模板包里的 WEX 文件，而不是修改 WordeX 核心。`;

const encodedLlmGuide = encodeURIComponent(llmGuide);

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function highlightLine(line: string) {
  if (line.trimStart().startsWith("%")) {
    return `<span class="wex-comment">${escapeHtml(line)}</span>`;
  }

  let escaped = escapeHtml(line);
  escaped = escaped.replace(/(\[[^\]\n]*\])/g, '<span class="wex-option">$1</span>');
  escaped = escaped.replace(/(\\begin\{equation\*?\}|\\end\{equation\*?\}|\\\[|\\\]|\\\(|\\\)|\$[^$]*\$)/g, '<span class="wex-math">$1</span>');
  escaped = escaped.replace(/(\\[A-Za-z*]+)/g, '<span class="wex-command">$1</span>');
  escaped = escaped.replace(/([{}])/g, '<span class="wex-brace">$1</span>');
  return escaped;
}

function highlightWex(source: string) {
  return source.split("\n").map(highlightLine).join("\n");
}
---

<Layout title="WordeX 写法说明" description="WordeX 文档写法与命令参考。" canonicalPath="/wordex/docs" theme="wordex">
  <section class="border-b border-line bg-elev">
    <div class="section-shell py-12">
      <p class="editorial-kicker text-xs text-accent">WordeX 写法说明</p>
      <div class="mt-4 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <h1 class="max-w-4xl font-display text-4xl font-semibold tracking-tight text-content md:text-5xl">WordeX 写法说明</h1>
          <p class="mt-5 text-base leading-7 text-muted">
            这里介绍 WordeX 的写法和命令。你（或 AI）只要按这套写法描述内容，模板就会决定它如何输出成规范的 Word 文档。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <button
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-theme border border-line-strong bg-surface px-5 py-2.5 text-sm font-semibold text-content shadow-soft transition hover:border-accent hover:text-accent"
            type="button"
            data-copy-doc
            data-copy-content={encodedLlmGuide}
          >
            复制给大模型
          </button>
          <ButtonLink href="/wordex">打开 WordeX</ButtonLink>
          <ButtonLink href="/products/wordex" variant="secondary">产品介绍</ButtonLink>
        </div>
      </div>
    </div>
  </section>

  <div class="section-shell grid gap-10 py-12 lg:grid-cols-[220px_minmax(0,1fr)_220px]">
    <aside class="hidden lg:block">
      <nav class="sticky top-24 rounded-theme border border-line bg-surface p-4">
        <p class="editorial-kicker text-xs text-faint">目录</p>
        <ul class="mt-4 space-y-2">
          {navItems.map(([label, href]) => (
            <li>
              <a class="focus-ring block rounded-md px-3 py-2 text-sm font-medium text-muted transition hover:bg-accent-soft hover:text-accent" href={href}>{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="min-w-0">
      <section id="overview" class="scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">概览</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">WordeX 是做什么的</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WordeX 不试图复刻完整 Word 界面，而是把正式文档拆成两层：内容源文件描述写什么，模板描述怎么排版和有哪些字段约束。这样，技术报告、期刊论文、通知和企业交付文档就能被反复生成、审阅和修订。
        </p>
        <div class="mt-6 rounded-theme border border-line bg-surface p-5">
          <h3 class="font-display text-lg font-semibold text-content">核心思路</h3>
          <p class="mt-3 text-sm leading-6 text-muted">内容源文件 + 模板 → 统一结构 → Word .docx</p>
        </div>
      </section>

      <section id="lifecycle-overview" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">生成流程</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">从写作到 Word 文档</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WordeX 的生成过程很直接：源文件先被解析并载入模板与配置，再整理成统一结构，最后输出为 Word 文档。
        </p>
        <div class="mt-8 grid gap-4">
          {lifecycleSteps.map(([title, text], index) => (
            <article class="grid gap-4 rounded-theme border border-line bg-surface p-5 sm:grid-cols-[48px_1fr]">
              <span class="flex h-10 w-10 items-center justify-center rounded-theme bg-content text-sm font-semibold text-bg">{index + 1}</span>
              <div>
                <h3 class="font-display text-lg font-semibold text-content">{title}</h3>
                <p class="mt-2 text-sm leading-6 text-muted">{text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="project-workspace" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">文档项目</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">在浏览器里管理文档项目</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WordeX 用项目来组织源文件、模板和素材。项目页可以创建、进入或删除项目；编辑页展示文件树和编辑器，并支持上传文件或目录。
        </p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {[
            ["文件树", "管理 .wex、.txt、.md、.json、.csv、.tex 和图片素材。"],
            ["编辑器", "为 .wex 提供语法高亮、提示标记、行号、搜索和括号匹配。"],
            ["项目素材", "相对资源从项目根目录解析，图表可引用 assets/ 下的文件。"],
            ["生成结果", "生成当前打开的 .wex 文件，并下载得到的 .docx。"]
          ].map(([title, text]) => (
            <div class="rounded-theme border border-line bg-surface p-5">
              <h3 class="font-display text-lg font-semibold text-content">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">{text}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="wex-basics" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">写法基础</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">写内容本身，而不是调 Word 样式</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WEX 使用类 LaTeX 的命令写法。普通正文直接写自然段；标题、元数据、图片、公式、表格和引用用反斜杠命令表达。
        </p>
        <p class="mt-3 text-sm leading-6 text-faint">
          官网文档使用静态高亮展示写法，不加载完整在线编辑器。
        </p>
        <pre class="wex-code mt-6 overflow-x-auto rounded-theme bg-content p-5 text-sm leading-7 text-bg"><code set:html={highlightWex(quickstartCode)} /></pre>
        <div class="mt-6 rounded-theme border border-line bg-surface p-5">
          <h3 class="font-display text-lg font-semibold text-content">表格</h3>
          <p class="mt-2 text-sm leading-6 text-muted">表格支持简单的竖线写法，也支持结构化单元格。图片、公式和表格可以加标签，并在正文中引用。</p>
          <pre class="wex-code wex-code-light mt-4 overflow-x-auto rounded-theme bg-surface-strong p-4 text-sm leading-7 text-muted"><code set:html={highlightWex(tableCode)} /></pre>
        </div>
      </section>

      <section id="core-commands" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">命令参考</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">支持的内置命令</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          以下命令来自 WordeX 默认命令表。表格内部的 row、th、td 由表格解析器处理；公式语法由解析器直接支持。
        </p>
        <div class="mt-8 grid gap-5">
          {commandGroups.map((group) => (
            <section class="rounded-theme border border-line bg-surface p-5">
              <h3 class="font-display text-xl font-semibold text-content">{group.title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">{group.text}</p>
              <div class="mt-5 divide-y divide-line">
                {group.commands.map(([syntax, description]) => (
                  <div class="grid gap-2 py-3 md:grid-cols-[minmax(220px,0.72fr)_1fr]">
                    <code class="rounded-md bg-surface-strong px-2.5 py-1.5 font-mono text-sm font-semibold text-accent">{syntax}</code>
                    <p class="text-sm leading-6 text-muted">{description}</p>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section id="template-packages" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">模板</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">模板决定排版规则</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          模板通过 include 载入。内置模板使用 @builtin 前缀，自定义模板可以放在项目路径、当前文件路径或用户全局目录里。模板可以定义页面、编号、样式 role 和字段别名。
        </p>
        <pre class="wex-code mt-6 overflow-x-auto rounded-theme bg-content p-5 text-sm leading-7 text-bg"><code set:html={highlightWex(templateCode)} /></pre>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {["page.wex", "styles.wex", "aliases.wex"].map((file) => (
            <div class="rounded-theme border border-line bg-surface p-5">
              <h3 class="font-display text-lg font-semibold text-content">{file}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">模板里可维护的 WEX 文件。</p>
            </div>
          ))}
        </div>
      </section>

      <section id="docx-template-extraction" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">从 Word 提取模板</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">用现有 Word 文档生成模板初稿</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WordeX 可以把一份参考 Word 文档提取成可编辑的模板初稿。这个流程用于生成后续可维护的模板，不承诺对任意 Word 文档做一次性无损复刻。
        </p>
        <pre class="mt-6 overflow-x-auto rounded-theme bg-content p-5 text-sm leading-7 text-bg"><code>{extractionCode}</code></pre>
        <div class="mt-6 rounded-theme border border-line-strong bg-accent-soft p-5">
          <h3 class="font-display text-lg font-semibold text-content">边界说明</h3>
          <p class="mt-2 text-sm leading-6 text-muted">
            参考 Word 文档只在提取阶段读取。正式生成仍走 WEX 到 DOCX 的标准链路，不会在生成阶段回读原始 Word 内容做修补。
          </p>
        </div>
      </section>

      <section id="availability" class="mt-16 scroll-mt-24">
        <p class="editorial-kicker text-xs text-accent">测试状态</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-content">在线编辑器入口</h2>
        <p class="mt-4 text-base leading-7 text-muted">
          WordeX 在线编辑器目前处于内部测试阶段。通过测试后，这里会承载在线文档项目。
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/wordex">查看在线入口</ButtonLink>
          <ButtonLink href="/products/wordex" variant="secondary">返回产品页</ButtonLink>
        </div>
      </section>
    </article>

    <aside class="hidden xl:block">
      <nav class="sticky top-24 rounded-theme border border-line bg-surface p-4">
        <p class="editorial-kicker text-xs text-faint">本页目录</p>
        <ul class="mt-4 space-y-2">
          {navItems.map(([label, href]) => (
            <li>
              <a class="focus-ring block rounded-md py-1 text-sm text-muted transition hover:text-accent" href={href}>{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </div>
  <script>
    const copyButton = document.querySelector("[data-copy-doc]");

    async function copyText(text: string) {
      if (!navigator.clipboard?.writeText) {
        throw new Error("Clipboard API is not available.");
      }

      await navigator.clipboard.writeText(text);
    }

    copyButton?.addEventListener("click", async () => {
      const button = copyButton as HTMLButtonElement;
      const originalText = button.textContent ?? "复制给大模型";
      const encoded = button.dataset.copyContent;

      if (!encoded) {
        return;
      }

      try {
        await copyText(decodeURIComponent(encoded));
        button.textContent = "已复制";
      } catch {
        button.textContent = "复制失败";
      }

      window.setTimeout(() => {
        button.textContent = originalText;
      }, 1800);
    });
  </script>
  <style>
    .wex-code code {
      font-family: "IBM Plex Mono", Consolas, "Cascadia Mono", "Microsoft YaHei UI", monospace;
      white-space: pre;
    }

    .wex-command {
      color: #8ce0ff;
      font-weight: 700;
    }

    .wex-option {
      color: #d8b4fe;
    }

    .wex-math {
      color: #a7f3d0;
    }

    .wex-comment {
      color: #94a3b8;
      font-style: italic;
    }

    .wex-brace {
      color: #f8fafc;
      font-weight: 700;
    }

    .wex-code-light .wex-command {
      color: #0f6684;
    }

    .wex-code-light .wex-option {
      color: #6d3db8;
    }

    .wex-code-light .wex-math {
      color: #1f7a4d;
    }

    .wex-code-light .wex-comment {
      color: #7a8596;
    }

    .wex-code-light .wex-brace {
      color: #5c6575;
    }
  </style>
</Layout>
