---
import Layout from "../../components/Layout.astro";
import ButtonLink from "../../components/ButtonLink.astro";

const navItems = [
  ["Overview", "#overview"],
  ["Lifecycle", "#lifecycle-overview"],
  ["Project workspace", "#project-workspace"],
  ["WEX basics", "#wex-basics"],
  ["Core commands", "#core-commands"],
  ["Template packages", "#template-packages"],
  ["DOCX extraction", "#docx-template-extraction"],
  ["Availability", "#availability"]
];

const lifecycleSteps = [
  ["Write source", "作者或大模型编写 .wex 文件，描述文档标题、元数据、章节、图表、公式和引用。"],
  ["Execute state", "WordeX 载入 include 和模板包，执行配置、样式、字段别名等状态变更。"],
  ["Compile IR", "编译器把语义结构转换为中间表示，保留章节、段落、题注、编号和引用关系。"],
  ["Render DOCX", "DOCX renderer 将 IR 和最终 theme 渲染为 Microsoft Word 可打开的 .docx 文件。"]
];

const quickstartCode = `\\include{@builtin/tech.report.basic}

\\title{电磁兼容测试技术报告}
\\issuer{某某检测中心}
\\date{2026-05-24}

\\section{测试概述}

本报告用于记录样品电磁兼容测试过程。场强计算公式为 $E = \\frac{V}{d}$。

\\figure{assets/test-setup.png}[caption=测试布置示意图,label=fig:setup,width=420]

测试布置见\\ref{fig:setup}。`;

const tableCode = `\\table{测试设备清单}[label=tab:equipment,style=grid]{
| 设备名称 | 型号 | 编号 |
| 接收机 | ESR 7 | A001 |
}`;

const templateCode = `\\include{@builtin/tech.report.basic}

\\style{section.1}{
  size: 18
  color: "#1F4E79"
}

\\alias{journalyear}{meta:journalYear}
\\journalyear{2026}`;

const extractionCode = `npm run wordex -- extract-template ./reference.docx -o ./templates/my.template --name my.template
npm run wordex -- verify-template ./templates/my.template
npm run wordex -- build ./main.wex -o ./dist/my-template-check.docx`;

const commandGroups = [
  {
    title: "Template and config",
    text: "控制 include、页面配置、编号、渲染和样式，主要由模板包使用。",
    commands: [
      ["\\include{path}", "载入模板或其他 WEX 文件。支持 @builtin、@project、@current、@user 和相对路径。"],
      ["\\config{name}{value}", "写入规则配置，例如 requiredMeta、allowedBlocks、maxSectionDepth。"],
      ["\\page{...}", "等价于 \\config{page}{...}，描述纸张、页边距、分栏、页眉页脚等页面规则。"],
      ["\\numbering{...}", "等价于 \\config{numbering}{...}，描述章节、图表、公式等编号规则。"],
      ["\\render{...}", "等价于 \\config{render}{...}，描述渲染阶段选项。"],
      ["\\style{role}{patch}", "修改最终 theme 中的样式 role，支持 key=value 和结构化块。"],
      ["\\alias{name}{meta:key}", "为模板字段注册友好的元数据命令，例如 \\journalyear{2026}。"]
    ]
  },
  {
    title: "Common metadata",
    text: "描述标题、日期、签发单位和通用元数据。",
    commands: [
      ["\\title{...}", "文档标题。"],
      ["\\issuer{...}", "签发单位、出具单位或署名单位。"],
      ["\\date{YYYY-MM-DD}", "文档日期。"],
      ["\\recipients{...}", "主送对象；支持顿号、中文逗号或英文逗号分隔。"],
      ["\\meta{key}{value}", "写入任意结构化元数据路径，例如 journal.name.zh。"]
    ]
  },
  {
    title: "Journal metadata",
    text: "期刊、论文和报告模板常用的内置元数据命令。",
    commands: [
      ["\\doi{...}", "DOI。"],
      ["\\editornote{...}", "编辑说明。"],
      ["\\author{...}", "作者；可重复使用形成作者列表。"],
      ["\\affiliation{...}", "作者单位；可重复使用。"],
      ["\\classification{...}", "分类号。"],
      ["\\abstract{...}", "中文摘要。"],
      ["\\keywords{...}", "中文关键词；按分号、逗号、顿号分隔。"],
      ["\\correspondence{...}", "通信作者或联系信息；可重复使用。"],
      ["\\englishtitle{...}", "英文标题。"],
      ["\\englishauthor{...}", "英文作者；可重复使用。"],
      ["\\englishaffiliation{...}", "英文单位；可重复使用。"],
      ["\\englishabstract{...}", "英文摘要。"],
      ["\\englishkeywords{...}", "英文关键词；按分隔符拆分。"],
      ["\\fund{...}", "基金项目。"],
      ["\\received{...}", "收稿日期。"],
      ["\\revised{...}", "修回日期。"],
      ["\\authorbio{...}", "作者简介；可重复使用。"]
    ]
  },
  {
    title: "Structure and content",
    text: "构建正文结构、段落、列表、附件、题注和标签。",
    commands: [
      ["\\section{...}", "一级标题，可带 [role=...] 覆盖样式 role。"],
      ["\\subsection{...}", "二级标题，可带 [role=...]。"],
      ["\\subsubsection{...}", "三级标题，可带 [role=...]。"],
      ["\\paragraph{...}", "显式段落；可带 [role=docx.someStyle]。"],
      ["\\item{...}", "列表项。"],
      ["\\attachment{...}[from=...]", "附件块，from 指向项目内文件。"],
      ["\\caption{...}", "显式题注块。"],
      ["\\label{id}", "把标签附加到前一个可编号结构，例如公式。"]
    ]
  },
  {
    title: "Media, tables, and references",
    text: "插入图片、表格、交叉引用和参考文献。",
    commands: [
      ["\\figure{path}[caption=...,label=...,width=...]", "图片；支持 captionEn、role、captionRole。"],
      ["\\table{caption}[label=...,style=grid]{...}", "表格；支持 pipe 表格和结构化单元格。"],
      ["\\row[header]{...}", "结构化表格内部命令，定义一行。"],
      ["\\th[colspan=...,rowspan=...]{...}", "结构化表格内部命令，定义表头单元格。"],
      ["\\td[colspan=...,rowspan=...]{...}", "结构化表格内部命令，定义普通单元格。"],
      ["\\bibitem{id}{text}", "声明参考文献条目。"],
      ["\\cite{id}", "正文内引用参考文献，渲染为编号交叉引用。"],
      ["\\ref{id}", "正文内引用图片、表格或公式标签。"]
    ]
  },
  {
    title: "Math syntax",
    text: "公式不是普通命令注册项，但由解析器支持，并由编译阶段编号和渲染。",
    commands: [
      ["$...$", "行内公式。"],
      ["\\(...\\)", "行内公式。"],
      ["\\[...\\]", "不带 equation 环境的展示公式。"],
      ["\\begin{equation}...\\end{equation}", "编号展示公式，可紧跟 \\label{eq:id}。"],
      ["\\begin{equation*}...\\end{equation*}", "不编号展示公式。"]
    ]
  }
];

const commandReferenceText = commandGroups
  .map((group) => [
    `### ${group.title}`,
    group.text,
    "",
    ...group.commands.map(([syntax, description]) => `- \`${syntax}\`：${description}`)
  ].join("\n"))
  .join("\n\n");

const llmGuide = `# WordeX / WEX 使用说明

WordeX 是面向中文正式 Word 文档的语义化文档编译器。作者或大模型编写 .wex 源文件描述文档语义，模板包决定这些语义如何渲染为 Word .docx。

## 核心概念

- 不要把 WordeX 当作在线 Word。WordeX 的重点是用源文件和模板包稳定生成 .docx。
- .wex 文件描述标题、元数据、章节、段落、图片、表格、公式、引用和参考文献。
- 模板包描述页面、样式、编号、字段别名和渲染规则。
- 输出是标准 Word .docx，可在 Microsoft Word 中继续打开和编辑。

## 编译生命周期

WEX source -> parse -> execute state -> compile IR -> render DOCX

1. Write source：编写 .wex 文件。
2. Execute state：载入 include 和模板包，执行配置、样式、字段别名等状态变更。
3. Compile IR：把语义结构转换为中间表示，保留章节、段落、题注、编号和引用关系。
4. Render DOCX：将 IR 和最终 theme 渲染为 .docx 文件。

## 常用命令

${commandReferenceText}

## 路径前缀

- @builtin/：仓库内置模板目录。
- @project/：当前项目根目录。
- @current/：当前文件所在目录。
- @user/：用户全局 WEX 目录。
- 无前缀路径等价于相对当前文件。

## 科技报告示例

\`\`\`latex
${quickstartCode}
\`\`\`

## 表格示例

\`\`\`latex
${tableCode}
\`\`\`

## 模板和样式示例

\`\`\`latex
${templateCode}
\`\`\`

常见样式 role 包括 title、paragraph、section.1、section.2、section.3、formula.display、figure.caption、table.default、table.caption、references.heading、reference.item。

## DOCX 模板提取

WordeX 可以把参考 DOCX 提取成可编辑的 WEX 模板包初稿。参考 DOCX 只在提取阶段读取，正式编译仍走 WEX -> DOCX 的标准链路。

\`\`\`bash
${extractionCode}
\`\`\`

生成的模板包通常包含：

- index.wex
- page.wex
- styles.wex
- aliases.wex
- AGENTS.md
- package.json
- assets/

模板效果与原 DOCX 有差异时，优先修改模板包里的 WEX 文件，而不是修改 WordeX 核心编译器。`;

const encodedLlmGuide = encodeURIComponent(llmGuide);

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function highlightLine(line: string) {
  if (line.trimStart().startsWith("%")) {
    return `<span class="wex-comment">${escapeHtml(line)}</span>`;
  }

  let escaped = escapeHtml(line);
  escaped = escaped.replace(/(\[[^\]\n]*\])/g, '<span class="wex-option">$1</span>');
  escaped = escaped.replace(/(\\begin\{equation\*?\}|\\end\{equation\*?\}|\\\[|\\\]|\\\(|\\\)|\$[^$]*\$)/g, '<span class="wex-math">$1</span>');
  escaped = escaped.replace(/(\\[A-Za-z*]+)/g, '<span class="wex-command">$1</span>');
  escaped = escaped.replace(/([{}])/g, '<span class="wex-brace">$1</span>');
  return escaped;
}

function highlightWex(source: string) {
  return source.split("\n").map(highlightLine).join("\n");
}
---

<Layout title="WordeX 说明文档" description="WordeX semantic document compiler documentation." canonicalPath="/wordex/docs">
  <section class="border-b border-ink/10 bg-white">
    <div class="section-shell py-12">
      <p class="text-sm font-semibold uppercase tracking-wider text-leaf">WordeX Docs</p>
      <div class="mt-4 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <h1 class="max-w-4xl text-4xl font-semibold tracking-normal text-ink md:text-5xl">WordeX 说明文档</h1>
          <p class="mt-5 max-w-3xl text-base leading-7 text-ink/64">
            WordeX 是面向中文正式文档的语义化编辑和编译链路。作者或大模型编写 .wex 源文件，模板包决定它如何输出为 Word .docx。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <button
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-lg border border-ink/12 bg-white px-5 py-2.5 text-sm font-semibold text-ink shadow-sm transition hover:border-leaf hover:text-leaf"
            type="button"
            data-copy-doc
            data-copy-content={encodedLlmGuide}
          >
            复制给大模型
          </button>
          <ButtonLink href="/wordex">打开 WordeX</ButtonLink>
          <ButtonLink href="/products/wordex" variant="secondary">产品介绍</ButtonLink>
        </div>
      </div>
    </div>
  </section>

  <div class="section-shell grid gap-10 py-12 lg:grid-cols-[220px_minmax(0,1fr)_220px]">
    <aside class="hidden lg:block">
      <nav class="sticky top-24 rounded-lg border border-ink/10 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">Docs</p>
        <ul class="mt-4 space-y-2">
          {navItems.map(([label, href]) => (
            <li>
              <a class="focus-ring block rounded-md px-3 py-2 text-sm font-medium text-ink/64 transition hover:bg-mint hover:text-leaf" href={href}>{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="min-w-0">
      <section id="overview" class="scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Overview</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">What WordeX does</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          WordeX 不试图复刻完整 Word 界面，而是把正式文档拆成两层：内容源文件描述语义，模板包描述版式和字段约束。这样，技术报告、期刊论文、通知和企业交付文档可以被重复生成、审阅和修订。
        </p>
        <div class="mt-6 rounded-lg border border-ink/10 bg-white p-5">
          <h3 class="text-lg font-semibold text-ink">Core idea</h3>
          <p class="mt-3 text-sm leading-6 text-ink/64">WEX source + template package -> compiled IR -> Word .docx</p>
        </div>
      </section>

      <section id="lifecycle-overview" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Lifecycle overview</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">From WEX source to Word document</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          WordeX 的编译链路围绕语义状态机展开。源文件先被解析并执行 include、配置和样式，再编译为中间表示，最后由 DOCX renderer 输出文档。
        </p>
        <div class="mt-8 grid gap-4">
          {lifecycleSteps.map(([title, text], index) => (
            <article class="grid gap-4 rounded-lg border border-ink/10 bg-white p-5 sm:grid-cols-[48px_1fr]">
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-ink text-sm font-semibold text-white">{index + 1}</span>
              <div>
                <h3 class="text-lg font-semibold text-ink">{title}</h3>
                <p class="mt-2 text-sm leading-6 text-ink/64">{text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="project-workspace" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Project workspace</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Browser workspace for document projects</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          WordeX Editor 使用项目工作区组织源文件、模板和素材。项目页可以创建、进入或删除项目；编辑页展示文件树和编辑器，并支持上传文件或目录。
        </p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {[
            ["File tree", "管理 .wex、.txt、.md、.json、.csv、.tex 和图片素材。"],
            ["CodeMirror editor", "为 .wex 提供语法高亮、lint 标记、行号、搜索和括号匹配。"],
            ["Project assets", "相对资源从项目根目录解析，图表可引用 assets/ 下的文件。"],
            ["Compile output", "编译当前打开的 .wex 文件，并下载生成的 .docx。"]
          ].map(([title, text]) => (
            <div class="rounded-lg border border-ink/10 bg-white p-5">
              <h3 class="text-lg font-semibold text-ink">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-ink/64">{text}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="wex-basics" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">WEX basics</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Write semantics, not Word styling</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          WEX 使用类 LaTeX 命令语法。普通正文直接写自然段；标题、元数据、图片、公式、表格和引用使用反斜杠命令表达。
        </p>
        <p class="mt-3 text-sm leading-6 text-ink/56">
          WordeX 在线编辑器使用 CodeMirror 6 提供 .wex 高亮、lint、搜索和颜色值编辑；官网文档使用静态高亮，不加载编辑器依赖。
        </p>
        <pre class="wex-code mt-6 overflow-x-auto rounded-lg bg-ink p-5 text-sm leading-7 text-white"><code set:html={highlightWex(quickstartCode)} /></pre>
        <div class="mt-6 rounded-lg border border-ink/10 bg-white p-5">
          <h3 class="text-lg font-semibold text-ink">Tables</h3>
          <p class="mt-2 text-sm leading-6 text-ink/64">表格支持简单 pipe 写法，也支持结构化单元格。图片、公式和表格可以使用 label，并通过 ref 在正文中引用。</p>
          <pre class="wex-code wex-code-light mt-4 overflow-x-auto rounded-lg bg-cloud p-4 text-sm leading-7 text-ink/76"><code set:html={highlightWex(tableCode)} /></pre>
        </div>
      </section>

      <section id="core-commands" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Core commands</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Built-in commands accepted by the compiler</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          以下命令来自 WordeX 默认命令注册表。表格内部的 row、th、td 由 table 解析器处理；公式语法由解析器直接支持。
        </p>
        <div class="mt-8 grid gap-5">
          {commandGroups.map((group) => (
            <section class="rounded-lg border border-ink/10 bg-white p-5">
              <h3 class="text-xl font-semibold text-ink">{group.title}</h3>
              <p class="mt-2 text-sm leading-6 text-ink/60">{group.text}</p>
              <div class="mt-5 divide-y divide-ink/10">
                {group.commands.map(([syntax, description]) => (
                  <div class="grid gap-2 py-3 md:grid-cols-[minmax(220px,0.72fr)_1fr]">
                    <code class="rounded-md bg-cloud px-2.5 py-1.5 font-mono text-sm font-semibold text-leaf">{syntax}</code>
                    <p class="text-sm leading-6 text-ink/64">{description}</p>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section id="template-packages" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Template packages</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Templates control rendering rules</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          模板通过 include 载入。内置模板使用 @builtin 前缀，自定义模板可以通过项目路径、当前文件路径或用户全局目录组织。模板可以定义页面、编号、样式 role 和字段 alias。
        </p>
        <pre class="wex-code mt-6 overflow-x-auto rounded-lg bg-ink p-5 text-sm leading-7 text-white"><code set:html={highlightWex(templateCode)} /></pre>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {["page.wex", "styles.wex", "aliases.wex"].map((file) => (
            <div class="rounded-lg border border-ink/10 bg-white p-5">
              <h3 class="text-lg font-semibold text-ink">{file}</h3>
              <p class="mt-2 text-sm leading-6 text-ink/64">模板包中的可维护 WEX 文件。</p>
            </div>
          ))}
        </div>
      </section>

      <section id="docx-template-extraction" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">DOCX template extraction</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Start a template from a reference DOCX</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          WordeX 可以把参考 DOCX 提取为可编辑的 WEX 模板包初稿。这个流程用于生成后续可维护的模板资产，不承诺对任意 DOCX 做一次性无损复刻。
        </p>
        <pre class="mt-6 overflow-x-auto rounded-lg bg-ink p-5 text-sm leading-7 text-white"><code>{extractionCode}</code></pre>
        <div class="mt-6 rounded-lg border border-leaf/20 bg-mint p-5">
          <h3 class="text-lg font-semibold text-ink">Boundary</h3>
          <p class="mt-2 text-sm leading-6 text-ink/64">
            参考 DOCX 只在提取阶段读取。正式编译仍走 WEX 到 DOCX 的标准链路，不在编译阶段回读原始 Word XML 做 patch。
          </p>
        </div>
      </section>

      <section id="availability" class="mt-16 scroll-mt-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Availability</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">Online editor path</h2>
        <p class="mt-4 text-base leading-7 text-ink/68">
          官网已预留 /wordex 作为 WordeX 在线编辑器入口。正式部署完成后，该路径会承载在线项目工作区；当前页面不公开私有仓库地址。
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/wordex">前往 /wordex</ButtonLink>
          <ButtonLink href="/products/wordex" variant="secondary">返回产品页</ButtonLink>
        </div>
      </section>
