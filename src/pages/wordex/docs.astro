    <aside class="hidden xl:block">
      <nav class="sticky top-24 rounded-lg border border-ink/10 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">On this page</p>
        <ul class="mt-4 space-y-2">
          {navItems.map(([label, href]) => (
            <li>
              <a class="focus-ring block rounded-md py-1 text-sm text-ink/56 transition hover:text-leaf" href={href}>{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </div>
  <script>
    const copyButton = document.querySelector("[data-copy-doc]");

    async function copyText(text: string) {
      if (!navigator.clipboard?.writeText) {
        throw new Error("Clipboard API is not available.");
      }

      await navigator.clipboard.writeText(text);
    }

    copyButton?.addEventListener("click", async () => {
      const button = copyButton as HTMLButtonElement;
      const originalText = button.textContent ?? "复制给大模型";
      const encoded = button.dataset.copyContent;

      if (!encoded) {
        return;
      }

      try {
        await copyText(decodeURIComponent(encoded));
        button.textContent = "已复制";
      } catch {
        button.textContent = "复制失败";
      }

      window.setTimeout(() => {
        button.textContent = originalText;
      }, 1800);
    });
  </script>
