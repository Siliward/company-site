---
interface Faq {
  question: string;
  answer: string;
}

interface Props {
  items: Faq[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-line rounded-theme-lg border border-line bg-surface">
  {items.map((item) => (
    <details class="group p-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-content">
        {item.question}
        <span class="text-xl text-accent transition group-open:rotate-45">+</span>
      </summary>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-muted">{item.answer}</p>
    </details>
  ))}
</div>
