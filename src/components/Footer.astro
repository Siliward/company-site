---
import { company } from "../data/company";
import { withBase } from "../utils/paths";

const groups = [
  {
    title: "Products",
    links: [
      { href: "/products/friday", label: "Friday" },
      { href: "/products/wordex", label: "WordeX" },
      { href: "/wordex", label: "WordeX Online" },
      { href: "/download", label: "Download" },
      { href: "/pricing", label: "Pricing" }
    ]
  },
  {
    title: "Trust",
    links: [{ href: "/privacy", label: "Privacy" }, { href: "/terms", label: "Terms" }, { href: "/third-party", label: "Third-party" }]
  },
  {
    title: "Company",
    links: [{ href: "/updates", label: "Updates" }, { href: `mailto:${company.contactEmail}`, label: company.contactEmail }]
  }
];
---

<footer class="mt-24 border-t border-ink/10 bg-white">
  <div class="section-shell grid gap-10 py-12 md:grid-cols-[1.4fr_2fr]">
    <div>
      <div class="flex items-center gap-3">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-ink text-sm font-bold text-white">SW</span>
        <span class="font-semibold text-ink">{company.name}</span>
      </div>
      <p class="mt-3 text-sm font-medium text-ink/72">{company.legalNameZh}</p>
      <p class="mt-1 text-xs text-ink/48">{company.legalNameEn}</p>
      <p class="mt-4 max-w-md text-sm leading-6 text-ink/64">{company.description}</p>
      <p class="mt-6 text-xs text-ink/48">© 2026 {company.name}. All rights reserved.</p>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      {groups.map((group) => (
        <div>
          <h2 class="text-sm font-semibold text-ink">{group.title}</h2>
          <ul class="mt-4 space-y-3">
            {group.links.map((link) => (
              <li>
                <a class="focus-ring rounded-md text-sm text-ink/64 transition hover:text-leaf" href={withBase(link.href)}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
