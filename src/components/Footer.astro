---
import { company } from "../data/company";
import { withBase } from "../utils/paths";

const groups = [
  {
    title: "产品",
    links: [
      { href: "/products/wordex", label: "WordeX 文档工具" },
      { href: "/wordex/docs", label: "写法说明" }
    ]
  },
  {
    title: "信任与合规",
    links: [
      { href: "/privacy", label: "隐私政策" },
      { href: "/terms", label: "用户协议" },
      { href: "/third-party", label: "第三方与开源说明" }
    ]
  },
  {
    title: "公司",
    links: [
      { href: `mailto:${company.contactEmail}`, label: company.contactEmail }
    ]
  }
];
---

<footer class="mt-24 border-t border-line bg-elev">
  <div class="section-shell grid gap-10 py-14 md:grid-cols-[1.4fr_2fr]">
    <div>
      <div class="flex items-center gap-2.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-theme bg-accent text-sm font-bold text-accent-contrast">硅</span>
        <span class="font-display text-lg font-semibold text-content">{company.name}</span>
      </div>
      <p class="mt-4 text-sm font-medium text-content">{company.legalNameZh}</p>
      <p class="mt-1 text-xs text-faint">{company.legalNameEn}</p>
      <p class="mt-4 max-w-md text-sm leading-7 text-muted">{company.description}</p>
      <p class="mt-6 text-xs text-faint">© 2026 {company.name}. 保留所有权利。</p>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      {groups.map((group) => (
        <div>
          <h2 class="font-display text-sm font-semibold text-content">{group.title}</h2>
          <ul class="mt-4 space-y-3">
            {group.links.map((link) => (
              <li>
                <a class="focus-ring rounded-md text-sm text-muted transition hover:text-accent" href={withBase(link.href)}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
