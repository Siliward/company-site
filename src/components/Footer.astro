---
import { company } from "../data/company";
import { withBase } from "../utils/paths";

const groups = [
  {
    title: "产品",
    links: [
      { href: "/products/wordex", label: "WordeX" },
    ]
  },
  {
    title: "信任与合规",
    links: [
      { href: "/privacy", label: "隐私政策" },
      { href: "/terms", label: "用户协议" }
    ]
  },
  {
    title: "公司",
    links: [
      { href: `mailto:${company.businessEmail}`, label: "商务合作：contact@siliward.cn" },
      { href: `mailto:${company.feedbackEmail}`, label: "用户反馈：feedback@siliward.cn" }
    ]
  }
];

const linkClass =
  "focus-ring inline-flex items-center gap-1.5 rounded-md text-sm font-medium text-muted transition hover:text-accent hover:underline hover:underline-offset-4";
---

<footer class="mt-24 border-t border-line bg-elev">
  <div class="section-shell grid gap-10 py-14 md:grid-cols-[1.4fr_2fr]">
    <div>
      <div class="flex items-center gap-2.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-theme bg-accent text-sm font-bold text-accent-contrast">硅</span>
        <span class="font-display text-lg font-semibold text-content">{company.name}</span>
      </div>
      <p class="mt-4 text-sm font-medium text-content">{company.legalNameZh}</p>
      <p class="mt-1 text-xs text-faint">{company.legalNameEn}</p>
      <p class="mt-4 max-w-md text-sm leading-7 text-muted">{company.description}</p>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      {groups.map((group) => (
        <div>
          <h2 class="font-display text-sm font-semibold text-content">{group.title}</h2>
          <ul class="mt-4 space-y-3">
            {group.links.map((link) => (
              <li>
                <a class="focus-ring rounded-md text-sm text-muted transition hover:text-accent" href={withBase(link.href)}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
  <div class="border-t border-line">
    <div class="section-shell flex flex-col items-center justify-between gap-3 py-5 text-center sm:flex-row sm:text-left">
      <p class="text-sm text-faint">© 2026 {company.name} 保留所有权利</p>
      <a
        class={linkClass}
        href="https://beian.miit.gov.cn/"
        rel="noreferrer"
        target="_blank"
      >
        <svg
          aria-hidden="true"
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M3 2.5h10v11H3z"
            stroke="currentColor"
            stroke-width="1.35"
            stroke-linejoin="round"
          />
          <path
            d="M5.25 5.25h5.5M5.25 8h5.5M5.25 10.75h3.4"
            stroke="currentColor"
            stroke-width="1.35"
            stroke-linecap="round"
          />
        </svg>
        {company.filingNumber}
      </a>
      <a
        class={linkClass}
        href={`https://beian.mps.gov.cn/#/query/webSearch?code=${company.publicSecurityFilingCode}`}
        rel="noreferrer"
        target="_blank"
      >
        <svg
          aria-hidden="true"
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M8 1.5 13 3.2v3.6c0 3.2-2 6.1-5 7.3-3-1.2-5-4.1-5-7.3V3.2l5-1.7Z"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linejoin="round"
          />
          <path
            d="M5.7 7.7 7.2 9.2 10.5 5.9"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        {company.publicSecurityFilingNumber}
      </a>
    </div>
  </div>
</footer>
