---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
}

import { withBase } from "../utils/paths";

const { href, variant = "primary" } = Astro.props;
const classes = variant === "primary"
  ? "bg-accent text-accent-contrast hover:opacity-90"
  : "border border-line-strong bg-surface text-content hover:border-accent hover:text-accent";
const resolvedHref = withBase(href);
---

<a class={`focus-ring inline-flex min-h-11 items-center justify-center rounded-theme px-5 py-2.5 text-sm font-semibold shadow-soft transition ${classes}`} href={resolvedHref}>
  <slot />
</a>
